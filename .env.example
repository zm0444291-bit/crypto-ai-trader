APP_ENV=local
APP_NAME=crypto-ai-trader
DATABASE_URL=sqlite:///./data/crypto_ai_trader.sqlite3
CONFIG_DIR=./config
LOG_LEVEL=INFO

# Do not put real keys in this file.
BINANCE_API_KEY=
BINANCE_API_SECRET=
OPENAI_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# AI scoring backend: "http" (default) or "minimax"
AI_SCORING_BACKEND=http
AI_SCORING_URL=
AI_SCORING_TIMEOUT=30

# MiniMax OpenAI-compatible settings (used when AI_SCORING_BACKEND=minimax)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M2.1
MINIMAX_TIMEOUT=30
